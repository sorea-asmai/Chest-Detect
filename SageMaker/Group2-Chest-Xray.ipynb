import sagemaker
from sagemaker.model import Model

sagemaker_session = sagemaker.Session()
role = sagemaker.get_execution_role()

# Target hardware instance type
DEPLOYMENT_INSTANCE = "ml.m5.xlarge"

# Your exact path from the team S3 bucket configuration
model_s3_url = "s3://group2-chest-xray-dataset-2026/models/model.tar.gz"

# Generic model instantiation that bypasses the PyTorchModel import completely
pytorch_model = Model(
    image_uri=sagemaker.image_uris.retrieve(
        framework="pytorch",
        region=sagemaker_session.boto_region_name,
        version="2.0.0",
        py_version="py310",
        image_scope="inference",
        instance_type=DEPLOYMENT_INSTANCE
    ),
    model_data=model_s3_url,
    role=role,
    entry_point="code/inference.py",  # Points directly inside the uploaded tar.gz
    source_dir=None                   # Tells SageMaker NOT to look for local files on your screen
)

print("Starting deployment infrastructure. This takes 5-8 minutes...")

# Spin up host infrastructure
predictor = pytorch_model.deploy(
    initial_instance_count=1,
    instance_type=DEPLOYMENT_INSTANCE,       
    endpoint_name="mura-efficientnet-b0" # Matches client.py defaults exactly
)

print("Infrastructure configuration deployed. Endpoint is live and ready!")
